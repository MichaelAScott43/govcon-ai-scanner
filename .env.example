# GovCon AI Scanner – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to source control.

# Required: Your SAM.gov API key
# Register at https://api.data.gov/signup/ (free)
# After registering, request access to the SAM.gov Opportunities API
SAM_API_KEY=your_sam_api_key_here

# Optional: Server port (defaults to 3000)
PORT=3000

# ---------------------------------------------------------------------------
# Datadog APM & Monitoring
# ---------------------------------------------------------------------------
# Set to "true" to enable Datadog APM (automatically enabled in production).
# In development it is OFF by default so you don't need an agent locally.
DD_ENABLED=false

# Your Datadog service name — appears in every trace, log, and metric
DD_SERVICE=govcon-ai-scanner

# Environment label shown in Datadog (e.g. development, staging, production)
DD_ENV=development

# App version — tag every trace and deployment with the release version
DD_VERSION=1.0.0

# Datadog site — use the one that matches your account region:
#   US1 (default):  datadoghq.com
#   US3:            us3.datadoghq.com
#   US5:            us5.datadoghq.com
#   EU:             datadoghq.eu
#   AP1:            ap1.datadoghq.com
DD_SITE=datadoghq.com

# Datadog Agent host — leave as localhost if the agent runs on the same machine/container
DD_TRACE_AGENT_HOSTNAME=localhost
DD_TRACE_AGENT_PORT=8126

# DogStatsD port for runtime metrics (CPU, memory, event-loop lag)
DD_DOGSTATSD_PORT=8125

# Set to "true" to enable continuous CPU/heap profiling (adds slight overhead)
DD_PROFILING_ENABLED=false

# Log level for the dd-trace library itself (error | warn | info | debug)
DD_TRACE_LOG_LEVEL=error
