# GovCon AI Scanner – Environment Variables
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to source control.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (default: localhost dev ports)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
# Get a free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/govcon?retryWrites=true&w=majority

# ---------------------------------------------------------------------------
# Authentication (JWT)
# ---------------------------------------------------------------------------
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_change_this

# ---------------------------------------------------------------------------
# SAM.gov API
# ---------------------------------------------------------------------------
# Register at https://api.data.gov/signup/ (free)
# Then request access to the SAM.gov Opportunities API
SAM_API_KEY=your_sam_api_key_here

# ---------------------------------------------------------------------------
# Email (choose ONE option)
# ---------------------------------------------------------------------------
# Option A: Gmail (use an App Password, not your real password)
GMAIL_USER=youraddress@gmail.com
GMAIL_PASSWORD=your_gmail_app_password

# Option B: SendGrid
# SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Sender address shown in outgoing emails
EMAIL_FROM=noreply@govconscanner.com

# ---------------------------------------------------------------------------
# Datadog APM & Monitoring (optional)
# ---------------------------------------------------------------------------
DD_ENABLED=false
DD_SERVICE=govcon-ai-scanner
DD_ENV=development
DD_VERSION=2.0.0
DD_SITE=datadoghq.com
DD_TRACE_AGENT_HOSTNAME=localhost
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125
DD_PROFILING_ENABLED=false
DD_TRACE_LOG_LEVEL=error
